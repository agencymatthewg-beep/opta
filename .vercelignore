# Ignore everything by default
/*

# Root manifests needed for pnpm workspace install
!/package.json
!/pnpm-lock.yaml
!/pnpm-workspace.yaml

# Include Opta Local web apps + shared package used by builds
!/1-Apps
/1-Apps/*
!/1-Apps/optalocal
/1-Apps/optalocal/*
!/1-Apps/optalocal/1O-Opta-Init
!/1-Apps/optalocal/1R-Opta-Accounts
!/1-Apps/optalocal/1S-Opta-Status
!/1-Apps/optalocal/1T-Opta-Home
!/1-Apps/optalocal/1U-Opta-Help
!/1-Apps/optalocal/1V-Opta-Learn
!/1-Apps/optalocal/1X-Opta-Admin
!/1-Apps/optalocal/1L-Opta-Local
/1-Apps/optalocal/1L-Opta-Local/*
!/1-Apps/optalocal/1L-Opta-Local/web

!/6-Packages
/6-Packages/*
!/6-Packages/6D-UI

# Exclude bulky/generated stuff within allowed tree
**/node_modules
**/.next
**/.vercel
**/dist
**/build
**/.turbo
**/coverage
**/playwright-report
**/test-results
**/.DS_Store
