{
  "name": "opta-help",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3006",
    "build": "next build --webpack",
    "start": "npx serve out -l 3006",
    "sync:learn-guides": "node scripts/sync-learn-guides-manifest.mjs",
    "validate:learn-links": "node scripts/validate-learn-links.mjs",
    "test": "node --test --experimental-strip-types lib/learn-about.test.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run lint && npm run sync:learn-guides && npm run validate:learn-links && npm run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
