{
  "buildCommand": "npm run check",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/init",
      "destination": "https://init.optalocal.com/init",
      "permanent": false
    },
    {
      "source": "/init/",
      "destination": "https://init.optalocal.com/init",
      "permanent": false
    },
    {
      "source": "/init/:path*",
      "destination": "https://init.optalocal.com/init/:path*",
      "permanent": false
    }
  ]
}
