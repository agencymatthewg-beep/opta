{
  "name": "optalocal-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "1D-Opta-CLI-TS",
    "1L-Opta-LMX-Dashboard",
    "1O-Opta-Init",
    "1P-Opta-Code-Universal",
    "1R-Opta-Accounts",
    "1S-Opta-Status",
    "1T-Opta-Home",
    "1U-Opta-Help",
    "1V-Opta-Learn",
    "1X-Opta-Admin",
    "1O-Opta-Init/desktop-manager"
  ],
  "scripts": {
    "apps:list": "node scripts/opta-local-workspace.mjs list",
    "apps:verify": "node scripts/opta-local-workspace.mjs verify",
    "registry:sync": "node scripts/sync-websites-registry.mjs",
    "registry:check": "node scripts/sync-websites-registry.mjs --check",
    "clean:local": "node scripts/clean-local-artifacts.mjs",
    "clean:local:dry": "node scripts/clean-local-artifacts.mjs --dry-run",
    "clean:local:deep": "node scripts/clean-local-artifacts.mjs --deep",
    "docs:check": "node scripts/docs/docs-health-check.mjs",
    "monitor:synthetic": "node scripts/synthetic-web-health.mjs",
    "check:all": "node scripts/opta-local-workspace.mjs run all check --continue-on-error",
    "build:all": "node scripts/opta-local-workspace.mjs run all build --continue-on-error",
    "dev:1d": "node scripts/opta-local-workspace.mjs run 1d dev",
    "dev:1m": "node scripts/opta-local-workspace.mjs run 1m dev",
    "dev:1o": "node scripts/opta-local-workspace.mjs run 1o dev",
    "dev:1p": "node scripts/opta-local-workspace.mjs run 1p dev",
    "dev:1r": "node scripts/opta-local-workspace.mjs run 1r dev",
    "dev:1s": "node scripts/opta-local-workspace.mjs run 1s dev",
    "dev:1t": "node scripts/opta-local-workspace.mjs run 1t dev",
    "dev:1u": "node scripts/opta-local-workspace.mjs run 1u dev",
    "dev:1v": "node scripts/opta-local-workspace.mjs run 1v dev",
    "dev:1x": "node scripts/opta-local-workspace.mjs run 1x dev",
    "check:1o": "node scripts/opta-local-workspace.mjs run 1o check",
    "release:opta-init:prepare": "npm --prefix 1O-Opta-Init run validate:release-contract && npm --prefix 1O-Opta-Init run sync:desktop-manifests && npm --prefix 1O-Opta-Init run sync:manager-updates && npm --prefix 1O-Opta-Init run sync:vercel-redirects"
  }
}
