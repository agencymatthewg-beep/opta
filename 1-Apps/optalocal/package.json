    "dev:1r": "node scripts/opta-local-workspace.mjs run 1r dev",
    "dev:1s": "node scripts/opta-local-workspace.mjs run 1s dev",
    "dev:1t": "node scripts/opta-local-workspace.mjs run 1t dev",
    "dev:1u": "node scripts/opta-local-workspace.mjs run 1u dev",
    "dev:1v": "node scripts/opta-local-workspace.mjs run 1v dev",
