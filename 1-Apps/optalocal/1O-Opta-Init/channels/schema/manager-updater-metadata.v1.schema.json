{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://init.optalocal.com/schemas/manager-updater-metadata.v1.schema.json",
  "title": "Opta Init Desktop Manager Updater Metadata v1",
  "description": "Tauri updater static feed metadata for the Opta Init desktop manager.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestVersion",
    "channel",
    "publishedAt",
    "version",
    "notes",
    "pub_date",
    "platforms"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "channel": {
      "type": "string",
      "enum": ["stable", "beta"]
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "notes": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "pub_date": {
      "type": "string",
      "format": "date-time"
    },
    "platforms": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^(darwin|windows|linux)-[A-Za-z0-9_-]+$": {
          "$ref": "#/$defs/platformRelease"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "platformRelease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "signature"],
      "properties": {
        "url": {
          "$ref": "#/$defs/httpsUrl"
        },
        "signature": {
          "type": "string",
          "minLength": 16,
          "maxLength": 4096
        }
      }
    }
  }
}
