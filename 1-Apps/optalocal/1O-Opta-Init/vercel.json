{
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "framework": null,
  "redirects": [
    {
      "source": "/downloads/opta-cli/v0.5.0-alpha.15/opta-cli-npm.tgz",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/v0.5.0-alpha.15/opta-cli-npm.tgz",
      "permanent": false
    },
    {
      "source": "/downloads/opta-daemon/v0.4.1/opta-daemon-macos-universal.tar.gz",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/opta-daemon-v0.4.1/opta-daemon-macos-universal.tar.gz",
      "permanent": false
    },
    {
      "source": "/downloads/opta-daemon/v0.4.1/opta-daemon-windows-x64.zip",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/opta-daemon-v0.4.1/opta-daemon-windows-x64.zip",
      "permanent": false
    },
    {
      "source": "/downloads/opta-daemon/v0.0.0-beta.test.5/opta-daemon-macos-universal.tar.gz",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/opta-daemon-v0.0.0-beta.test.5/opta-daemon-macos-universal.tar.gz",
      "permanent": false
    },
    {
      "source": "/downloads/opta-daemon/v0.0.0-beta.test.5/opta-daemon-windows-x64.zip",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/opta-daemon-v0.0.0-beta.test.5/opta-daemon-windows-x64.zip",
      "permanent": false
    },
    {
      "source": "/desktop-updates/manager/stable/:version/:asset",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/opta-init-manager-stable-v:version/:asset",
      "permanent": false
    },
    {
      "source": "/desktop-updates/manager/beta/:version/:asset",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/opta-init-manager-beta-v:version/:asset",
      "permanent": false
    },
    {
      "source": "/downloads/opta-cli/latest",
      "destination": "https://github.com/agencymatthewg-beep/opta/releases/download/v0.5.0-alpha.15/opta-cli-npm.tgz",
      "permanent": false
    },
    {
      "source": "/downloads/cli",
      "destination": "/downloads/opta-cli/latest",
      "permanent": false
    },
    {
      "source": "/downloads/opta-init/latest/opta-init-mac.dmg",
      "destination": "https://init.optalocal.com/desktop-updates/manager/stable/0.7.3/Opta-Init-Manager_aarch64.dmg",
      "permanent": false
    },
    {
      "source": "/downloads/opta-init/latest/opta-init-windows-x64.exe",
      "destination": "https://init.optalocal.com/desktop-updates/manager/stable/0.7.3/opta-init-windows-x64.exe",
      "permanent": false
    },
    {
      "source": "/downloads/opta-init/latest/Opta-Init-Manager_x64-setup.nsis.zip",
      "destination": "https://init.optalocal.com/desktop-updates/manager/stable/0.7.3/Opta-Init-Manager_x64-setup.nsis.zip",
      "permanent": false
    },
    {
      "source": "/downloads/opta-init/latest",
      "destination": "/downloads/opta-init/latest/opta-init-mac.dmg",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:; frame-src 'self' https:; worker-src 'self' blob:; form-action 'self'"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!_next/static|favicon.ico|robots.txt|sitemap.xml).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!_next|favicon.ico|robots.txt|sitemap.xml).*)",
      "destination": "/$1.html"
    }
  ]
}
