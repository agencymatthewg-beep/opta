{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Opta Init App Manager",
  "version": "0.7.2",
  "identifier": "com.optalocal.init.desktopmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Opta Init App Manager",
        "width": 1260,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "opta-init"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://init.optalocal.com/desktop-updates/stable.json"
      ],
      "pubkey": "dW50cnVzdGVk"
    }
  }
}
