{
  "name": "opta-init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run sync:desktop-manifests && npm run sync:manager-updates && next dev",
    "sync:desktop-manifests": "node scripts/sync-desktop-manifests.mjs",
    "sync:manager-updates": "node scripts/sync-manager-updates.mjs",
    "validate:release-manifests": "node scripts/validate-release-manifests.mjs",
    "validate:manager-update-metadata": "node scripts/validate-manager-update-metadata.mjs",
    "validate:manifest-links": "node scripts/validate-manifest-links.mjs",
    "validate:release-contract": "npm run validate:release-manifests && npm run validate:manager-update-metadata && npm run validate:manifest-links",
    "prebuild": "npm run sync:desktop-manifests && npm run sync:manager-updates",
    "build": "next build --webpack",
    "start": "node scripts/start-static.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
