#!/usr/bin/env bash
set -euo pipefail

SCRIPT_VERSION="2026.03.02"
CANONICAL_URL="https://init.optalocal.com/init"
INIT_SITE_URL="https://init.optalocal.com"
PLATFORM_URL="https://optalocal.com"

log() {
  printf '%s\n' "$*"
}

note() {
  log "==> $*"
}

warn() {
  log "WARN: $*" >&2
}

error() {
  log "ERROR: $*" >&2
}

note "Opta Init bootstrap (${SCRIPT_VERSION})"
note "Fetched from ${CANONICAL_URL}"

if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
  warn "Running as root is not required. Continue only if intentional."
fi

if [[ "$(uname -s)" != "Darwin" ]]; then
  warn "Opta Init bootstrap-managed install is macOS-only today."
  log ""
  log "Next steps:"
  log "1) Open ${INIT_SITE_URL}"
  log "2) Download the latest Opta Init manager package"
  log "3) Re-run this script on a supported macOS machine"
  exit 0
fi

ARCH="$(uname -m)"
if [[ "${ARCH}" != "arm64" ]]; then
  warn "Apple Silicon (arm64) is recommended. Detected: ${ARCH}"
fi

missing=()
for cmd in curl bash; do
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    missing+=("${cmd}")
  fi
done

if (( ${#missing[@]} > 0 )); then
  error "Missing required command(s): ${missing[*]}"
  error "Install the missing tools and rerun bootstrap."
  exit 1
fi

log ""
note "Bootstrap endpoint verified."
note "This script is intentionally non-destructive and performs no privileged changes."

log ""
log "Next steps:"
log "1) Open ${INIT_SITE_URL} and download Opta Init Manager (macOS)."
log "2) Install the manager package, then launch Opta Init."
log "3) Run: opta init"
log "4) Validate health: opta doctor"
log "5) Open Opta Local platform: ${PLATFORM_URL}"

log ""
log "Need this command again?"
log "curl -fsSL ${CANONICAL_URL} | bash"
