{
  "name": "opta-learn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3007",
    "build": "next build --webpack",
    "start": "next start --port 3007",
    "guide:new": "node ./scripts/new-guide.mjs",
    "guides:inventory": "node ./scripts/guides-inventory.mjs",
    "guides:inventory:check": "node ./scripts/check-guides-inventory.mjs",
    "guides:validate": "node ./scripts/validate-guides.mjs",
    "test:smoke": "node --test ./tests/guides-manifest.smoke.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run guides:validate && npm run guides:inventory:check && eslint .",
    "check": "npm run typecheck && npm run lint && npm run build && npm run test:smoke"
  },
  "dependencies": {
    "clsx": "^2",
    "framer-motion": "^12",
    "fuse.js": "^7",
    "lucide-react": "^0.575.0",
    "next": "^15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
