# Cloudflare Tunnel URLs for LAN service health checks.
# These are set in Vercel project settings (never commit real values).
OPTA_LMX_HEALTH_URL=https://lmx-health.optalocal.com
# Legacy fallback env name (supported for backward compatibility):
# OPTA_LMX_TUNNEL_URL=https://lmx-health.optalocal.com
OPTA_DAEMON_TUNNEL_URL=https://daemon-health.optalocal.com
# Optional: daemon deep-status endpoint (prefers /v3/health when set)
# OPTA_DAEMON_STATUS_URL=https://daemon-health.optalocal.com
# Optional: bearer token for daemon /v3/* probes
# OPTA_DAEMON_TOKEN=replace-with-daemon-bearer-token
# Optional: dedicated Opta Code Desktop status URL
# OPTA_CODE_URL=https://code.optalocal.com

# Optional: override the public URL for Opta Local (defaults to https://optalocal.com)
# OPTA_LOCAL_URL=https://optalocal.com

# Optional: override the Accounts portal URL (defaults to https://accounts.optalocal.com)
# OPTA_ACCOUNTS_URL=https://accounts.optalocal.com

# Optional: override the Admin portal URL (defaults to https://opta-admin.vercel.app)
# OPTA_ADMIN_URL=https://opta-admin.vercel.app
